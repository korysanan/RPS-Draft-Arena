--- !u!114 &5000000002
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5000000000}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: a1b2c3d4e5f60718293a4b5c6d7e8f90, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  displayImage: {fileID: 5100000003}
  descriptionText: {fileID: 5200000003}
  prevButton: {fileID: 5300000004}
  nextButton: {fileID: 5400000004}
  pages:
  - {fileID: -3481158978272654105, guid: 61acbf36436d58c4aa5430852f566324, type: 3}
  - {fileID: -4542661919298480239, guid: ebe8b8f6b7bde114abb8e407d0b187ad, type: 3}
  - {fileID: 7749225359416461487, guid: 0e198a3ce6c9f5e4f85da853c0d2111d, type: 3}
  - {fileID: 917968334298923832, guid: bb3987c25b9372a45a2e403197d33ff9, type: 3}
  - {fileID: -1383874932749559920, guid: d9315f228940c194286c57cfe5088b1f, type: 3}
  - {fileID: -6283738102369405915, guid: 0eea1441a18869b419aafa9905fa19b3, type: 3}
  - {fileID: -4251215921840659566, guid: 3e30669ec40d882409974b74bff67ba6, type: 3}
  - {fileID: -3191615738517461966, guid: 7b1212854c7db5e4dadd555ffbbdf3ba, type: 3}
  - {fileID: -3191615738517461966, guid: 7b1212854c7db5e4dadd555ffbbdf3ba, type: 3}
  - {fileID: -6956562935307425796, guid: c3d3d6621a91f044aa3ffa902dc176c1, type: 3}
  descriptions:
  - "\uAC8C\uC784\uC744 \uC2DC\uC791\uD558\uAE30 \uC804, \uC774 \uD654\uBA74\uC5D0\uC11C
    AI \uB09C\uC774\uB3C4, RPS \uC885\uB958, \uACBD\uAE30 \uBC29\uC2DD\uC744 \uC120\uD0DD\uD569\uB2C8\uB2E4.
    \n\uC6D0\uD558\uB294 \uC124\uC815\uC744 \uACE0\uB978 \uB4A4 \uD558\uB2E8\uC758
    [\uD655\uC778] \uBC84\uD2BC\uC744 \uB204\uB974\uBA74 \uAC8C\uC784\uC774 \uC2DC\uC791\uB429\uB2C8\uB2E4."
  - "\uAC8C\uC784 \uC2DC\uC791 \uC9C1\uD6C4 \uB098\uD0C0\uB098\uB294 \uD328 \uC120\uD0DD
    \uD654\uBA74\uC785\uB2C8\uB2E4. \uD654\uBA74\uC5D0 \uD3BC\uCCD0\uC9C4 7\uC7A5\uC758
    \uCE74\uB4DC \uC911 \uD558\uB098\uB97C \uACE8\uB77C AI\uC640 \uB300\uACB0\uD558\uBA70,
    \n\uC2B9\uB9AC\uD558\uBA74 \uC120\uD53D/\uD6C4\uD53D\uC744 \uC9C1\uC811 \uC120\uD0DD\uD560
    \uC218 \uC788\uACE0 \uD328\uBC30\uD558\uBA74 AI\uAC00 \uB300\uC2E0 \uC120\uD0DD\uD569\uB2C8\uB2E4."
  - "\uC790\uC2E0\uC758 \uCC28\uB840\uAC00 \uB418\uBA74 \uC911\uC559\uC5D0 \uD3BC\uCCD0\uC9C4
    \uC18D\uC131 \uCE74\uB4DC \uC911 \uD558\uB098\uB97C \uC120\uD0DD\uD55C \uB4A4
    \uD558\uB2E8\uC758 [\uACB0\uC815] \uBC84\uD2BC\uC744 \uB20C\uB7EC \uD53D\uC744
    \uD655\uC815\uD558\uBA70, \n\uCE74\uB4DC\uB97C \uAE38\uAC8C \uB204\uB974\uBA74
    \uD574\uB2F9 \uCE74\uB4DC\uC758 \uC0C1\uC131 \uAD00\uACC4\uB97C \uC790\uC138\uD788
    \uD655\uC778\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4. \n\uC88C\xB7\uC6B0\uCE21\uC5D0\uB294
    Player\uC640 AI\uAC00 \uD68D\uB4DD\uD55C \uCE74\uB4DC\uC640 \uC810\uC218\uAC00
    \uD45C\uC2DC\uB418\uACE0, \n\uC88C\uCE21 \uD558\uB2E8\uC758 \uC0C1\uC131\uD45C
    \uBC84\uD2BC\uC73C\uB85C \uC804\uCCB4 \uC0C1\uC131 \uAD00\uACC4\uB97C \uD55C\uB208\uC5D0
    \uBCFC \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uC591\uCE21\uC758 \uB4DC\uB798\uD504\uD2B8\uAC00 \uBAA8\uB450 \uB05D\uB09C
    \uB4DC\uB798\uD504\uD2B8 \uC644\uB8CC \uD654\uBA74\uC785\uB2C8\uB2E4. \uBCF8\uACA9\uC801\uC778
    \uB300\uACB0\uC5D0 \uB4E4\uC5B4\uAC00\uAE30 \uC804 \uC57D 30\uCD08 \uB3D9\uC548
    \uC0C1\uB300\uAC00 \uC5B4\uB5A4 \uCE74\uB4DC\uB97C \uACE8\uB790\uB294\uC9C0 \uBD84\uC11D\uD558\uBA70
    \uC804\uB7B5\uC744 \uC138\uC6B0\uB294 \uC2DC\uAC04\uC73C\uB85C, \uC88C\xB7\uC6B0\uCE21
    \uD328\uB110\uC5D0\uC11C Player\uC640 AI\uAC00 \uD655\uBCF4\uD55C \uCE74\uB4DC\uB97C
    \uBE44\uAD50\uD558\uACE0 \uC88C\uCE21 \uD558\uB2E8 \uC0C1\uC131\uD45C \uBC84\uD2BC\uC73C\uB85C
    \uC18D\uC131 \uAC04 \uC0C1\uC131\uC744 \uC810\uAC80\uD560 \uC218 \uC788\uC2B5\uB2C8\uB2E4."
  - "\uB77C\uC6B4\uB4DC\uB9C8\uB2E4 \uCE74\uB4DC\uB97C \uB0B4\uB294 \uD53D \uD654\uBA74\uC785\uB2C8\uB2E4.
    \uC790\uC2E0\uC758 \uCC28\uB840\uC5D0 \uC911\uC559\uC758 \uCE74\uB4DC \uC911
    \uC774\uBC88 \uB77C\uC6B4\uB4DC\uC5D0 \uB0BC \uCE74\uB4DC \uD55C \uC7A5\uC744
    \uC120\uD0DD\uD55C \uB4A4 \uD558\uB2E8\uC758 [PICK] \uBC84\uD2BC\uC744 \uB204\uB974\uBA74
    \uBCA0\uD305 \uD654\uBA74\uC73C\uB85C \uB118\uC5B4\uAC11\uB2C8\uB2E4."
  - "\uCE74\uB4DC\uB97C \uB0B8 \uB4A4 \uB098\uD0C0\uB098\uB294 \uD3EC\uC778\uD2B8
    \uBCA0\uD305 \uD654\uBA74\uC785\uB2C8\uB2E4. \uD55C \uC2DC\uB9AC\uC988(\uCD1D
    5\uB9E4\uCE58)\uC5D0 100pt\uB97C \uB098\uB220 \uAC78 \uC218 \uC788\uC73C\uBA70,
    -5 / +5 \uBC84\uD2BC\uC73C\uB85C \uBCA0\uD305\uC561\uC744 \uC870\uC808\uD55C
    \uB4A4 [\uD655\uC815]\uC744 \uB204\uB985\uB2C8\uB2E4. \uAC01 \uB9E4\uCE58\uC758
    \uCD5C\uC18C \uBCA0\uD305\uC740 5pt\uC774\uACE0, \uC774\uD6C4 \uB9E4\uCE58\uB9C8\uB2E4
    \uCD5C\uC18C 5pt\uC529\uC740 \uB0A8\uACA8\uC57C \uD558\uBBC0\uB85C \uBCA0\uD305
    \uAC00\uB2A5 \uC0C1\uD55C\uC740 100 \u2212 (5 \xD7 \uB0A8\uC740 \uB9E4\uCE58
    \uC218)\uB85C \uC81C\uD55C\uB429\uB2C8\uB2E4(\uC608: \uCCAB \uB9E4\uCE58\uB294
    5~80pt). \uB2E8, \uB9C8\uC9C0\uB9C9 \uB9E4\uCE58\uC5D0\uC11C\uB294 \uB0A8\uC740
    \uD3EC\uC778\uD2B8 \uC804\uBD80\uAC00 \uC790\uB3D9\uC73C\uB85C \uBCA0\uD305\uB429\uB2C8\uB2E4."
  - "\uC591\uCE21\uC774 \uBCA0\uD305\uC744 \uB9C8\uCE5C \uB4A4 \uB098\uD0C0\uB098\uB294
    \uBCA0\uD305 \uACF5\uAC1C \uD654\uBA74\uC785\uB2C8\uB2E4. \uB098\uC640 \uC0C1\uB300\uAC00
    \uC774\uBC88 \uB9E4\uCE58\uC5D0 \uAC74 \uD3EC\uC778\uD2B8(\uC608: \uB098 15pt,
    \uC0C1\uB300 70pt)\uAC00 \uBA3C\uC800 \uACF5\uAC1C\uB418\uACE0, \uC774\uC5B4\uC11C
    \uC11C\uB85C \uD53D\uD55C \uCE74\uB4DC\uAC00 \uB4A4\uC9D1\uD788\uBA70 \uB450
    \uCE74\uB4DC\uC758 \uC0C1\uC131\uC5D0 \uB530\uB77C \uC2B9\uD328\uC640 \uD3EC\uC778\uD2B8
    \uD68D\uB4DD \uACB0\uACFC\uAC00 \uACB0\uC815\uB429\uB2C8\uB2E4."
  - "\uD55C \uB9E4\uCE58\uAC00 \uB05D\uB09C \uB4A4 \uB2E4\uC74C \uB9E4\uCE58\uB97C
    \uC9C4\uD589\uD558\uB294 \uACB0\uACFC \uBC18\uC601 \uD654\uBA74\uC785\uB2C8\uB2E4.
    \uC9C1\uC804 \uB9E4\uCE58\uC5D0\uC11C \uC0AC\uC6A9\uD55C \uCE74\uB4DC\uB294 \n\uC88C\xB7\uC6B0
    \uD328\uB110\uACFC \uC911\uC559\uC5D0\uC11C X \uD45C\uC2DC\uB85C \uBE44\uD65C\uC131\uD654\uB418\uC5B4
    \uB2E4\uC2DC \uB0BC \uC218 \uC5C6\uC73C\uBA70, \uC0C1\uB2E8\uC758 \uD3EC\uC778\uD2B8\uB294
    \uB9E4\uCE58 \uACB0\uACFC\uC5D0 \uB530\uB77C \uAC31\uC2E0\uB429\uB2C8\uB2E4."
  - "\uD3EC\uC778\uD2B8\uB294 \uC790\uC2E0\uC774 \uAC74 \uBCA0\uD305\uC561\uC744
    \uAE30\uC900\uC73C\uB85C \uC815\uC0B0\uB418\uBA70, \uC2B9\uD328\uC5D0 \uB530\uB77C
    \uB2E4\uC74C\uACFC \uAC19\uC774 \uCC98\uB9AC\uB429\uB2C8\uB2E4(\uC608\uC2DC:
    \uB098 15pt, \uC0C1\uB300 70pt \uBCA0\uD305).\n\uC2B9\uB9AC \uC2DC \u2014 \uBCA0\uD305\uC561\uC758
    2\uBC30\uB97C \uD68D\uB4DD (\uB098 30 : \uC0C1\uB300 0)\n\uBB34\uC2B9\uBD80 \uC2DC
    \u2014 \uAC01\uC790 \uC790\uC2E0\uC758 \uBCA0\uD305\uC561\uC744 \uD68C\uC218
    (\uB098 15 : \uC0C1\uB300 70)\n\uD328\uBC30 \uC2DC \u2014 \uC0C1\uB300\uAC00
    \uC591\uCABD \uBCA0\uD305\uC561 \uD569\uACC4\uB97C \uD68D\uB4DD (\uB098 0 : \uC0C1\uB300
    140)"
  - "\uD55C \uB77C\uC6B4\uB4DC\uC758 5\uAC1C \uB9E4\uCE58\uAC00 \uBAA8\uB450 \uB05D\uB09C
    \uB4A4 \uD45C\uC2DC\uB418\uB294 \uB77C\uC6B4\uB4DC \uACB0\uACFC \uD654\uBA74\uC785\uB2C8\uB2E4.
    \uB77C\uC6B4\uB4DC \uB3D9\uC548 \uC790\uC2E0\uACFC \uC0C1\uB300\uAC00 \uD68D\uB4DD\uD55C
    \uCD1D \uD3EC\uC778\uD2B8\uB97C \uBE44\uAD50\uD574 \n\uC2B9\uD328\uAC00 \uACB0\uC815\uB418\uBA70,
    \uB77C\uC6B4\uB4DC \uC810\uC218\uAC00 \uAC19\uC544 \uBB34\uC2B9\uBD80\uC77C \uACBD\uC6B0\uC5D0\uB294
    \uC11C\uB4E0 \uB9E4\uCE58 \uBC29\uC2DD\uC73C\uB85C \uD55C \uC7A5\uC744 \uB354
    \uACE8\uB77C \uC2B9\uBD80\uB97C \uAC00\uB9BD\uB2C8\uB2E4. \n[\uC138\uBD80 \uACB0\uACFC]
    \uBC84\uD2BC\uC73C\uB85C \uB9E4\uCE58\uBCC4 \uD3EC\uC778\uD2B8 \uC815\uC0B0 \uB0B4\uC5ED\uC744
    \uD655\uC778\uD560 \uC218 \uC788\uACE0, [\uB2E4\uC74C \uB77C\uC6B4\uB4DC] \uBC84\uD2BC\uC744
    \uB204\uB974\uBA74 \uB2E4\uC74C \uB77C\uC6B4\uB4DC\uB85C \uC9C4\uD589\uB429\uB2C8\uB2E4."
